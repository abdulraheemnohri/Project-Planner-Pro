# Project Planner Pro - Environment Variables

# Application
APP_NAME=Project Planner Pro
APP_DESCRIPTION=Developer Productivity Platform
APP_VERSION=0.1.0

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/project_planner_pro

# Redis
REDIS_URL=redis://localhost:6379/0

# Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8000

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=